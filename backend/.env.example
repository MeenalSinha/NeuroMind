# Server
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Auth
# Shared bearer token required for all state-changing (POST) endpoints:
# /api/incidents/{id}/investigate, /api/incidents/{id}/resolve,
# /api/security/contain/{id}, /api/incidents/_audit/log.
# Defaults to "neuromind-dev-key" so the app runs out of the box; set a
# strong value before deploying.
NEUROMIND_API_KEY=neuromind-dev-key

# AI Layer
# Set ANTHROPIC_API_KEY and USE_MOCK_AI=false to enable the real agentic
# tool-use loop (app.services.ai_service.run_agentic_investigation), where
# Claude decides which tools to call (telemetry, metrics, deployment
# history, memory graph, past incidents) and produces the final
# root-cause/business-impact/recommendations itself.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SPLUNK_HOSTED_MODEL_URL=
USE_MOCK_AI=true

# Data Layer
# NeuroMind uses SQLite (app/neuromind.db, created automatically) for
# persistence: investigations, organizational learnings, agent memory,
# incident/security state, and the audit log. POSTGRES_URL / NEO4J_* /
# REDIS_URL are reserved for a future managed-database migration and are
# not required to run the app.
POSTGRES_URL=postgresql+asyncpg://neuromind:neuromind@localhost:5432/neuromind
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neuromind123
REDIS_URL=redis://localhost:6379/0
USE_MOCK_GRAPH=true

# Splunk Layer
# Set SPLUNK_HOST, SPLUNK_TOKEN, and USE_MOCK_SPLUNK=false to enable real
# Splunk REST API calls:
#  - search()            -> /services/search/jobs/export (SPL queries)
#  - get_metrics()        -> mstats SPL against Observability metrics
#  - run_soar_playbook()  -> /rest/playbook/{name}/run (SOAR)
# SPLUNK_HOST should be the full base URL including scheme and port,
# e.g. https://your-splunk-instance:8089
# SPLUNK_TOKEN is a Splunk authentication token (Settings > Tokens).
# If live Splunk is unreachable or misconfigured, calls automatically
# fall back to realistic mock data (response includes "source":"mock").
SPLUNK_HOST=
SPLUNK_PORT=8089
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
SPLUNK_TOKEN=
SPLUNK_MCP_URL=
USE_MOCK_SPLUNK=true
